{
  "name": "Multi-Factor Strategy",
  "description": "Three-layer signal system combining macro regime, momentum, and mean reversion",
  "enabled": true,
  "run_interval_hours": 4,
  "layer_weights": {
    "macro": 0.30,
    "trend": 0.40,
    "reversion": 0.30
